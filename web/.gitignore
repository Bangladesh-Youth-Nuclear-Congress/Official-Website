# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# .env holds only the Supabase URL and publishable key. Both are shipped to the
# browser in the static bundle anyway, so they are public by construction —
# committing them keeps the repo buildable by anyone (and by CI) out of the box.
# Secret keys must never be added here; put them in .env.local, which stays ignored.
!.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
