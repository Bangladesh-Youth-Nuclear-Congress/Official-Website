# Supabase — public project settings.
#
# Both values below are meant to ship to the browser: the site is a static
# export, so anything NEXT_PUBLIC_* is baked into the JS bundle and visible to
# anyone. The publishable key grants nothing on its own — every table is behind
# Row Level Security, and the write paths require an admin session.
#
# The `secret` / `service_role` keys must NEVER appear in this file or anywhere
# else in the repo. They bypass RLS entirely.
NEXT_PUBLIC_SUPABASE_URL=https://asyxebpwkpzgqyhpegkj.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_VKLkj_FHHbzUICJvHI4IaA_aBCTKB5u
